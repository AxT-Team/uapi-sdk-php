    "free-api",
    "rest",
    "rest-api",
    "openapi",
    "client",
    "http",
    "ai",
    "agent"
  ],
  "authors": [
    {
      "name": "UAPI",
      "email": "dev@uapis.cn",
      "homepage": "https://uapis.cn"
    }
  ],
  "support": {
    "issues": "https://github.com/AxT-Team/uapi-sdk-php/issues",
    "source": "https://github.com/AxT-Team/uapi-sdk-php",
    "docs": "https://uapis.cn/docs"
  },
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.8"
  },
  "autoload": {
    "psr-4": {
      "Uapi\\": "src/"
    }
  }
